# Copy to .env and fill in. Never commit .env.

# Required: PostgreSQL connection string.
# Neon: paste your connection string from Neon dashboard (Connection string / URI). Must include ?sslmode=require
# Local Docker: use the line below and run "npm run db:up" first.
DATABASE_URL=postgresql://predictioninsider:predictioninsider_local@127.0.0.1:5433/predictioninsider

# Optional
PORT=5000
NODE_ENV=development
BACKEND_URL=http://127.0.0.1:5000
# How long after ingest before smart refresh / scheduled pipeline skips (1-168 hours). Default 6.
# PI_SMART_REFRESH_HOURS=6
# Python ingest POST timeout seconds (large rosters). Default 240.
# PI_INGEST_TIMEOUT_SEC=240
# FIRECRAWL_API_KEY=fc-xxxx
